# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
# VARS bank account recipient code (for commission splits)
PAYSTACK_VARS_RECIPIENT_CODE=RCP_your-vars-recipient-code

# Twilio (WhatsApp + SMS delivery via deliver-outreach)
# Find at console.twilio.com — Account Info panel
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+234xxxxxxxxxx
TWILIO_SMS_FROM=+234xxxxxxxxxx

# Resend (email delivery via deliver-outreach)
# Sending domain: bookwithvars.com (verified on Squarespace/Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Youverify KYC
YOUVERIFY_API_KEY=your-youverify-api-key
YOUVERIFY_BASE_URL=https://api.youverify.co

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Expo (mobile)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Next.js admin
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VARS commission rate (20%)
VARS_COMMISSION_PERCENT=20
