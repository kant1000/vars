{
  "name": "vars",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "audit:access": "powershell -ExecutionPolicy Bypass -File scripts/audit-access.ps1",
    "audit:access:network": "powershell -ExecutionPolicy Bypass -File scripts/audit-access.ps1 -CheckNetwork",
    "mobile": "yarn workspace @vars/mobile start",
    "admin": "yarn workspace @vars/admin dev",
    "landing": "yarn workspace @vars/landing dev",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/shared/src/database.types.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-webview": "~13.12.5",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.49",
    "react": "18.3.1"
  },
  "devDependencies": {
    "supabase": "^1.200.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
